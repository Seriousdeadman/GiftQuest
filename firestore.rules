rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- USERS ----
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---- COUPLES + ITEMS ----
    match /couples/{coupleId} {
      // Read if I'm a member of this couple doc
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      // Create if I'm included in the new members array
      allow create: if request.auth != null
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members;

      // Update if I'm a current member
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members;

      // Delete if I'm a current member
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;

      // Items subcollection: allowed if I'm a member of the parent couple
      match /items/{itemId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }
    }

    // ---- INVITES (top-level collection) ----
    match /invites/{inviteId} {
      // Sender creates an invite to someone else
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.coupleId is string;

      // Both sides can read/delete their invite rows
      allow read, delete: if request.auth != null
                          && (request.auth.uid == resource.data.toUid
                              || request.auth.uid == resource.data.fromUid);
    }
  }
}
